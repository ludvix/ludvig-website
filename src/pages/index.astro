---
import Layout from '../layouts/Layout.astro';
---
<Layout>
    <div id="background"></div> <!-- animated background -->

  <section id="hero">
    <h1>Hello, I’m Ludvig Kalberg!</h1>
    <h2>Welcome to my website</h2>
    <div id="links">
      <a href="#projects" class="primary">See My Projects</a>
      <a href="/wiki" class="primary">IT Wiki</a>
        <a href="/scripts" class="secondary">Scripts</a>
      <a href="#contact" class="secondary">Contact Me</a>
    </div>
  </section>

  <!-- About Me Section -->
  <section id="about" class="box" style="margin-top: 3rem; text-align: center;">
    <h2>About Me</h2>
    <img 
    src="/profile.png" 
    alt="Ludvig Kalberg" 
    style="width:150px; height:150px; border-radius:50%; object-fit:cover; margin-bottom:1rem;"
    />
  <p>
    Hey, this is me! I’m an IT-support apprentice who enjoys building and learning new things with technology.    
    When I’m not working with servers, networking, or programming, you’ll probably find me bouldering, 
    playing computer games or working on creative projects. 
  </p> 

    <div class="image-grid">
    <img src="/images/image1.jpg" alt="Img1">
    <img src="/images/image2.jpg" alt="Img2">
    <img src="/images/image3.jpg" alt="Img3">
  </div>

<div style="margin-top: 1.5rem;">
  <h3>Things I enjoy</h3>
  <p>
    ☁️ Cloud technologies<br>
    🔐 Cybersecurity<br>
    🌐 Networking<br>
    🧠 Learning new tech<br>
    💻 Programming & scripting<br>
    🎮 Computer games<br>
    🧗 Bouldering
  </p>
</div>

  </section>

  <!-- Projects Section -->
  <section id="projects" class="box" style="margin-top: 3rem; display: flex; flex-wrap: wrap; gap: 1.5rem; justify-content: center;">
    <div class="feature">
      <h2>Project 1 Header</h2>
      <p>Project 1 Paragraph.</p>
      <a href="/projects/project1" class="primary">View Project</a>
    </div>
    <div class="feature">
      <h2>Project 2 Header</h2>
      <p>Project 2 Paragraph.</p>
      <a href="/projects/project2" class="primary">View Project</a>
    </div>
	<div class="feature">
      <h2>Project 3 Header</h2>
      <p>Project 3 Paragraph.</p>
      <a href="/projects/project3" class="primary">View Project</a>
    </div>

  </section>

    <!-- Top TV Series Section -->
 <!--<section id="favorites" class="box mt-12 text-center">
  <h2 class="text-3xl font-bold mb-4">My Favorite TV Shows</h2>
  <p class="text-gray-700 mb-6">
    When it’s time to relax, I love diving into some epic TV series. 
    These are my favorites that I often come back to rewatch.
  </p>
  <a href="/top-tv" class="primary">See My Top TV Series</a>
</section>  --> 

<!-- Wiki Preview Section -->
<section id="wiki-preview" class="box" style="margin-top: 3rem; text-align: center;">
  <h2>Need Help? My IT Wiki</h2>
  <p>
  I created a simple IT wiki to explain tech concepts in plain, easy-to-understand words. 
  Whether you’re learning new things or just need a quick refresher, this is the place to start! 
  </p>
  <a href="/wiki" class="primary">Go to Wiki</a>
</section>

<section id="scripts-preview" class="box" style="margin-top: 3rem; text-align: center;">
  <h2>Scripts</h2>
  <p>
    Here you can find some useful Bash and PowerShell scripts for automation and everyday IT tasks.
  </p>
  <a href="/scripts" class="primary">Explore Scripts</a>
</section>

  <!-- Contact / Social Section -->
<section id="contact" class="box" style="margin-top: 3rem; text-align: center;">
  <h2>Get in Touch</h2>
  <p>Have a question or just want to say hi? Send me a message!</p>

  <!-- Contact Form -->
  <div style="max-width:400px; margin:0 auto; text-align:left;">
    <form id="contact-form" action="https://formspree.io/f/xlgggkgl" method="POST">
    <label for="email">Your Email:</label>
    <input 
      type="email" 
      name="email" 
      id="email" 
      placeholder="your@email.com" 
      required
      style="width:100%; padding:0.5rem; margin-bottom:0.5rem;"
    />

    <label for="message">Message:</label>
    <textarea 
      name="message" 
      id="message" 
      placeholder="Your message here..." 
      required
      style="width:100%; padding:0.5rem; margin-bottom:0.5rem;"
    ></textarea>

    <input type="hidden" name="_next" value="https://www.ludvigkalberg.com/thank-you">

    <button type="submit" class="primary" style="width:100%;">Send</button>
  </form>

  <div id="thankyou-message" style="display:none; color:rgb(247, 0, 255); text-align:center; margin-top:1rem;">
      Thanks for reaching out! I’ll get back to you soon.
  </div>
</div>


  <!-- GitHub Link -->
  <a href="https://github.com/ludvix" class="secondary" 
     style="display:block; margin-top:1rem; text-align:center;">
    GitHub
  </a>
</section>
<script type="module" src="/contact-form.js"></script>
</Layout>
