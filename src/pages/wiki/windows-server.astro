    src="/" 
    alt="Step 2 img" 
    style="
    max-width:150px; 
    height:auto; 
    flex-shrink:0; 
    border: 1px solid #ccc; 
    border-radius:4px; 
    box-shadow: 1px 1px 4px rgba(0,0,0,0.2);
