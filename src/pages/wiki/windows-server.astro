---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <div id="background"></div>

  <!-- Guide Title -->
  <section class="box" style="margin-top: 3rem; text-align: center;">
    <h1>Windows Server with Proxmox</h1>
    <p>Step-by-step guide to setting up a Windows Server in a virtual environment.</p>
  </section>

  <!-- Step-by-step guide -->
  <section class="box" style="margin-top: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
    
    <!-- Step 1 -->
    <div class="feature" style="display:flex; gap:1rem; align-items:flex-start;">
    <img 
    src="/" 
    alt="Step 1 img" 
    style="
      max-width:150px; 
      height:auto; 
      flex-shrink:0; 
      border: 1px solid #ccc; 
      border-radius:4px; 
      box-shadow: 1px 1px 4px rgba(0,0,0,0.2);
    "
    >
      <div>
        <h3>Step 1: </h3>
        <p>Download .</p>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="feature" style="display:flex; gap:1rem; align-items:flex-start;">
