    src="/" 
    alt="Step 3 img" 
    style="
      max-width:150px; 
      height:auto; 
      flex-shrink:0; 
      border: 1px solid #ccc; 
      border-radius:4px; 
      box-shadow: 1px 1px 4px rgba(0,0,0,0.2);
    "
    >
      <div>
        <h3>Step 3: </h3>
        <p>Start .</p>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="feature" style="display:flex; gap:1rem; align-items:flex-start;">
      <img 
    src="/" 
    alt="Step 4 img" 
    style="
      max-width:150px; 
      height:auto; 
      flex-shrink:0; 
      border: 1px solid #ccc; 
      border-radius:4px; 
      box-shadow: 1px 1px 4px rgba(0,0,0,0.2);
    "
    >
      <div>
        <h3>Step 4: </h3>
        <p>Install .</p>
